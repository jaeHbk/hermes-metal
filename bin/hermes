#!/usr/bin/env bash
# hermes — thin wrapper that runs src/cli.py with the project's venv Python.
#
# Resolves the repo root from the script's own location so the wrapper works
# whether invoked directly, via PATH, or through a symlink (`make install-cli`
# drops one in /usr/local/bin).
set -euo pipefail

# Follow symlinks so /usr/local/bin/hermes -> repo/bin/hermes still resolves
# the repo root correctly.
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
    DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
REPO_ROOT="$(cd -P "$(dirname "$SOURCE")/.." && pwd)"

VENV_PY="$REPO_ROOT/.venv/bin/python"

# `doctor` is the one subcommand that must keep working when the venv is
# broken — that's exactly when users reach for it. It is stdlib-only and
# imports nothing from src/backend, so route it directly to system python3
# whenever the venv isn't usable.
if [[ "${1:-}" == "doctor" ]] && [[ ! -x "$VENV_PY" ]]; then
    cd "$REPO_ROOT"
    exec /usr/bin/env python3 -m src.doctor "${@:2}"
fi

if [[ ! -x "$VENV_PY" ]]; then
    echo "hermes: missing $VENV_PY. Run 'make setup-venv' first," >&2
    echo "        or 'hermes doctor' to diagnose the install." >&2
    exit 1
fi

cd "$REPO_ROOT"
exec "$VENV_PY" -m src.cli "$@"
