# hermes-metal engine flags. Sourced; do NOT include shell logic.
# Consumed by Makefile and scripts/fetch_model.sh. Keep KEY=VALUE only.

# llama.cpp upstream. Note: ggerganov/llama.cpp redirects to ggml-org/llama.cpp;
# both URLs resolve to the same canonical repo.
LLAMA_CPP_REPO_URL=https://github.com/ggerganov/llama.cpp
# Tracks upstream HEAD by default. For reproducible builds, replace with a
# pinned tag (e.g. b4400) and rerun 'make init'.
LLAMA_CPP_REF=main

# Chat model: NousResearch's official first-party GGUF for Hermes-3-Llama-3.1-8B.
# Remote filename uses '.' separator (NousResearch convention); local target name
# is normalized to lowercase-hyphenated for ergonomics.
MODEL_REPO=NousResearch/Hermes-3-Llama-3.1-8B-GGUF
MODEL_FILE=hermes-8b-q4_k_m.gguf
MODEL_URL=https://huggingface.co/NousResearch/Hermes-3-Llama-3.1-8B-GGUF/resolve/main/Hermes-3-Llama-3.1-8B.Q4_K_M.gguf

# Embedding model: nomic-embed-text-v1.5 (768-dim, 8192 ctx, Matryoshka-capable).
# f16 GGUF is the recommended high-fidelity variant (~262 MiB).
EMBED_MODEL_REPO=nomic-ai/nomic-embed-text-v1.5-GGUF
EMBED_MODEL_FILE=nomic-embed-text-v1.5.f16.gguf
EMBED_MODEL_URL=https://huggingface.co/nomic-ai/nomic-embed-text-v1.5-GGUF/resolve/main/nomic-embed-text-v1.5.f16.gguf

# --- Speculative decoding (E5, hm-0y4) ---------------------------------------
# Draft model for speculative decoding (llama-server -md / --model-draft). The
# target Hermes-3-Llama-3.1-8B autoregressively VERIFIES batches of tokens
# proposed by a tiny, fast draft model; on Apple Silicon decode is UMA-
# bandwidth-bound (see THREAD tuning note below), so amortizing several tokens
# per target forward pass is the biggest decode lever available.
#
# Llama-3.2-1B is vocab-compatible with the Llama-3.1 target (mandatory for
# speculative decoding — the draft must share the target's tokenizer). The
# ~0.75 GB Q4_K_M draft is fully Metal-offloaded (DRAFT_N_GPU_LAYERS=99), so it
# adds resident footprint but stays in unified memory alongside the target.
# Provenance for the GGUF is recorded in models/DRAFT_MODEL.md; the file itself
# is gitignored (models/*.gguf), same as the target.
#
# These keys are consumed by the Makefile install-daemon render into
# daemon.plist.template (-md / -ngld / --spec-draft-n-max). They are REAL levers
# (the daemon picks them up on its next launch), not inert config: per the E2
# convention below, a key that nothing reads would be a misleading no-op. To
# realize the speedup the chat daemon must be (re)installed: `make install-daemon`.
# Leave MODEL_DRAFT_FILE empty to disable speculative decoding (render omits -md).
MODEL_DRAFT_FILE=llama-3.2-1b-instruct-q4_k_m.gguf
# Fully offload the draft model to Metal (it is tiny; CPU layers would bottleneck
# the draft pass and erase the speculative win). 99 = "all layers" per llama.cpp.
DRAFT_N_GPU_LAYERS=99
# Max tokens drafted per target verification step (llama-server --spec-draft-n-max,
# upstream default 3). 8 is a conservative starting point for a 1B-drafts-8B pair;
# acceptance-rate-driven tuning is deliberately left to a follow-up (this bead is
# a bounded experiment, not an A/B sweep).
DRAFT_N_MAX=8

# Server bindings. Chat server on 8080, dedicated embedding server on 8081.
ENGINE_PORT=8080
EMBED_PORT=8081

# KV cache quantization. q8_0 for both K and V. Note: quantized V REQUIRES
# flash attention (llama.cpp PR #7527), so FLASH_ATTENTION=1 is mandatory here.
CACHE_TYPE_K=q8_0
CACHE_TYPE_V=q8_0

# Flash attention. Passed as `-fa on` to llama-server (runtime flag, not a
# CMake build flag on Metal). Required by the q8_0 V cache above.
FLASH_ATTENTION=1

# Per-slot KV persistence directory. Server-side equivalent of llama-cli's
# --prompt-cache; used with POST /slots/{id}?action=save|restore.
# Relative to WORKING_DIR; the daemon plist resolves to {WORKING_DIR}/storage/slots.
SLOT_SAVE_PATH=storage/slots

# CPU thread tuning (--threads / --threads-batch): NO KNOB ADDED — measured no-op.
# E2 (hm-0li) hypothesis was that prefill is CPU-compute-bound and that matching
# --threads-batch to the physical P-core count would lift prefill t/s. A direct
# A/B sweep on the running llama-server (M3 Pro, 6 P + 6 E cores, full Metal
# offload) FALSIFIED this:
#   t/tb config:  2/2     6/6     8/6     8/8     12/12
#   prefill t/s:  ~333    ~330    ~332    ~333    ~333   (flat, within jitter)
#   decode  t/s:  ~23     ~24     ~23     ~23     ~24    (flat)
# Root cause: the GGUF is fully GPU-offloaded (device_info reports MTL0 Apple
# M3 Pro, all layers on Metal), so prefill is GPU-compute-bound and decode is
# UMA-bandwidth-bound. The CPU thread pool only drives sampling/glue work, which
# is off the critical path — so -t / -tb have ~0 effect on this tier.
# Decode thread count is therefore left at the host-topology default (THREAD_COUNT
# in config/host_topology.env, plumbed to llama-server's -t via the plist). No
# THREADS_BATCH key is introduced here: an engine_flags.env value that nothing
# reads would be a misleading, inert lever (threads are plumbed from
# host_topology.env, not this file).
# The real prefill/decode levers on Apple Silicon are batch/ubatch sizing (E3,
# hm-2f0) and speculative decoding (E5, hm-0y4), NOT CPU thread counts.
# NB: this conclusion is tier-specific. On a BASE chip running partly on CPU (no
# full Metal offload), thread tuning would matter — revisit per-tier if that
# config ships.
